        <button class="flex flex-col items-center gap-1 text-on-surface-variant">
            <span class="material-symbols-outlined">home</span>
            <span class="text-[10px] font-bold">Home</span>
        </button>
        <button class="flex flex-col items-center gap-1 text-primary">
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">auto_stories</span>
            <span class="text-[10px] font-bold">Sermons</span>
        </button>
        <button
            class="bg-primary -mt-10 w-14 h-14 rounded-full flex items-center justify-center text-on-primary shadow-xl shadow-primary/40">
            <span class="material-symbols-outlined">add</span>
        </button>
        <button class="flex flex-col items-center gap-1 text-on-surface-variant">
            <span class="material-symbols-outlined">event</span>
            <span class="text-[10px] font-bold">Events</span>
        </button>
        <button class="flex flex-col items-center gap-1 text-on-surface-variant">
            <span class="material-symbols-outlined">groups</span>
            <span class="text-[10px] font-bold">Ministries</span>
        </button>
    </nav>
    <div class="fixed inset-0 z-[100] flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm"
        id="upload-modal">
        <div
            class="bg-white dark:bg-neutral-900 w-full max-w-2xl rounded-3xl shadow-2xl overflow-hidden animate-in fade-in zoom-in duration-300">
            <!-- Modal Header -->
            <div
                class="px-8 py-6 border-b border-neutral-100 dark:border-neutral-800 flex justify-between items-center">
                <h2 class="text-2xl font-extrabold text-on-surface tracking-tight">Upload New Sermon</h2>
                <button class="p-2 hover:bg-neutral-100 dark:hover:bg-neutral-800 rounded-full transition-colors">
                    <span class="material-symbols-outlined text-outline">close</span>
                </button>
            </div>
            <!-- Modal Body / Form -->
            <div class="px-8 py-8 max-h-[70vh] overflow-y-auto scrollbar-hide">
                <form class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <!-- Sermon Title -->
                        <div class="md:col-span-2 space-y-2">
                            <label
                                class="text-sm font-bold text-on-surface-variant uppercase tracking-wider ml-1">Sermon
                                Title</label>
                            <input
                                class="w-full px-4 py-3.5 bg-surface-container-low border-none rounded-xl focus:ring-2 focus:ring-primary/20 focus:bg-surface-container-lowest transition-all placeholder:text-outline/50"
                                placeholder="Enter sermon title" type="text" />
                        </div>
                        <!-- Speaker Name -->
                        <div class="space-y-2">
                            <label
                                class="text-sm font-bold text-on-surface-variant uppercase tracking-wider ml-1">Speaker
                                Name</label>
                            <input
                                class="w-full px-4 py-3.5 bg-surface-container-low border-none rounded-xl focus:ring-2 focus:ring-primary/20 focus:bg-surface-container-lowest transition-all placeholder:text-outline/50"
                                placeholder="e.g. Pastor John Doe" type="text" />
                        </div>
                        <!-- Sermon Series -->
                        <div class="space-y-2">
                            <label
                                class="text-sm font-bold text-on-surface-variant uppercase tracking-wider ml-1">Sermon
                                Series</label>
                            <input
                                class="w-full px-4 py-3.5 bg-surface-container-low border-none rounded-xl focus:ring-2 focus:ring-primary/20 focus:bg-surface-container-lowest transition-all placeholder:text-outline/50"
                                placeholder="e.g. Walking in Faith" type="text" />
                        </div>
                        <!-- Service Date -->
                        <div class="space-y-2">
                            <label
                                class="text-sm font-bold text-on-surface-variant uppercase tracking-wider ml-1">Service
                                Date</label>
                            <input
                                class="w-full px-4 py-3.5 bg-surface-container-low border-none rounded-xl focus:ring-2 focus:ring-primary/20 focus:bg-surface-container-lowest transition-all text-on-surface-variant"
                                type="date" />
                        </div>
                        <!-- Scripture Reference -->
                        <div class="space-y-2">
                            <label
                                class="text-sm font-bold text-on-surface-variant uppercase tracking-wider ml-1">Scripture
                                Reference</label>
                            <input
                                class="w-full px-4 py-3.5 bg-surface-container-low border-none rounded-xl focus:ring-2 focus:ring-primary/20 focus:bg-surface-container-lowest transition-all placeholder:text-outline/50"
                                placeholder="e.g. John 3:16" type="text" />
                        </div>
                    </div>
                    <!-- Sermon Type (Chips) -->
                    <div class="space-y-3">
                        <label class="text-sm font-bold text-on-surface-variant uppercase tracking-wider ml-1">Sermon
                            Type</label>
                        <div class="flex flex-wrap gap-3">
                            <label
                                class="flex items-center gap-2 px-4 py-2 rounded-full bg-surface-container-low hover:bg-surface-container-high cursor-pointer transition-colors border border-transparent has-[:checked]:border-primary has-[:checked]:bg-primary-fixed">
                                <input checked="" class="hidden" name="type" type="radio" />
                                <span class="material-symbols-outlined text-lg">videocam</span>
                                <span class="font-medium">Video</span>
                            </label>
                            <label
                                class="flex items-center gap-2 px-4 py-2 rounded-full bg-surface-container-low hover:bg-surface-container-high cursor-pointer transition-colors border border-transparent has-[:checked]:border-primary has-[:checked]:bg-primary-fixed">
                                <input class="hidden" name="type" type="radio" />
                                <span class="material-symbols-outlined text-lg">headset</span>
                                <span class="font-medium">Audio</span>
                            </label>
                            <label
                                class="flex items-center gap-2 px-4 py-2 rounded-full bg-surface-container-low hover:bg-surface-container-high cursor-pointer transition-colors border border-transparent has-[:checked]:border-primary has-[:checked]:bg-primary-fixed">
                                <input class="hidden" name="type" type="radio" />
                                <span class="material-symbols-outlined text-lg">description</span>
                                <span class="font-medium">Text</span>
                            </label>
                        </div>
                    </div>
                    <!-- File Upload / URL -->
                    <div class="space-y-2">
                        <label class="text-sm font-bold text-on-surface-variant uppercase tracking-wider ml-1">Media
                            Content</label>
                        <div class="flex gap-2">
                            <input
                                class="flex-1 px-4 py-3.5 bg-surface-container-low border-none rounded-xl focus:ring-2 focus:ring-primary/20 focus:bg-surface-container-lowest transition-all placeholder:text-outline/50"
                                placeholder="Enter media URL (YouTube, Vimeo, etc.)" type="text" />
                            <button
                                class="px-4 py-3.5 bg-surface-container-high hover:bg-surface-container-highest rounded-xl font-bold transition-all flex items-center gap-2 text-sm whitespace-nowrap text-on-surface-variant"
                                type="button">
                                <span class="material-symbols-outlined">upload</span>
                                Choose File
                            </button>
                        </div>
                    </div>
                    <!-- Description -->
                    <div class="space-y-2">
                        <label
                            class="text-sm font-bold text-on-surface-variant uppercase tracking-wider ml-1">Description
                            / Notes</label>
                        <textarea
                            class="w-full px-4 py-3.5 bg-surface-container-low border-none rounded-xl focus:ring-2 focus:ring-primary/20 focus:bg-surface-container-lowest transition-all placeholder:text-outline/50 resize-none"
                            placeholder="Add internal notes or public description..." rows="3"></textarea>
                    </div>
                </form>
            </div>
            <!-- Modal Footer -->
            <div class="px-8 py-6 bg-surface-container-low/50 flex flex-col md:flex-row gap-3">
                <button
                    class="flex-1 py-4 bg-[#c0392b] hover:bg-[#a93226] text-white rounded-2xl font-extrabold text-lg shadow-xl shadow-red-900/20 transition-all hover:scale-[0.99] active:scale-95">
                    Save Sermon
                </button>
                <button
                    class="px-8 py-4 bg-transparent text-on-surface-variant hover:text-on-surface font-bold transition-colors">
                    Cancel
                </button>
            </div>
        </div>
    </div>
</body>

</html>